# Archon Project - Environment Configuration

# ========================================
# BACKEND
# ========================================

# Required: Groq API Key for LLM
# Get your free key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Server configuration
HOST=0.0.0.0
PORT=8000

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ========================================
# FRONTEND
# ========================================

# Backend WebSocket URL
ARCHON_API_URL=ws://localhost:8000/ws/run

# Backend HTTP API URL
ARCHON_HTTP_URL=http://localhost:8000/api

# ========================================
# SETUP INSTRUCTIONS
# ========================================

# 1. Copy this file to .env at the root level
#    cp .env.example .env

# 2. Update GROQ_API_KEY with your actual key from https://console.groq.com

# 3. Start backend:
#    cd backend && python main.py

# 4. Start frontend:
#    cd frontend && npm install && npm start

# 5. For production, update the API URLs to your hosted URLs:
#    ARCHON_API_URL=wss://your-railway-url/ws/run
#    ARCHON_HTTP_URL=https://your-railway-url/api